          "type": "question",
          "settings": {
            "title": "How can I return my order?",
            "text": "<p>Simply contact our customer service via our <strong>contact page</strong>. You will receive a reply with the return details within 24 hours.</p>"
          }
        },
        "question_L8d3xP": {
          "type": "question",
          "settings": {
            "title": "How can i track my order?",
            "text": "<p>Once your order has been processed, you will immediately receive a confirmation e-mail with your personal tracking details, which you can enter on our <strong>tracking page</strong>. This way you can always easily track your order.</p>"
          }
        },
        "question_TcLWwA": {
          "type": "question",
          "settings": {
            "title": "Is my payment secure?",
            "text": "<p><strong>Yes, your payment is 100% secure.</strong> We use industry-standard SSL encryption to protect your information, ensuring a safe and reliable checkout process.</p>"
          }
        }
      },
