        "question_t4YRrf": {
          "type": "question",
          "settings": {
            "title": "What if i'm unsure about sizing?",
            "text": "<p>If you're unsure about the fit, <strong>we recommend choosing a size up.</strong> This will give you a more comfortable fit, and you can always return the item if needed. For questions, you can also always reach our customer service team.</p>"
          }
        },
