{%- if section.settings.divider -%}
  <div class="section--divider">
{%- endif -%}

<div class="page-width page-width--narrow faq-custom-section" id="faq-section-{{ section.id }}">

  {%- if section.settings.title != blank -%}
    <header class="section-header faq-custom-header">
      <h2 class="section-header__title faq-custom-title">
        {{ section.settings.title | escape }}
      </h2>
    </header>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {% for block in section.blocks %}
            {% if block.type == 'question' %}
              {
                "@type": "Question",
                "name": {{ block.settings.title | json }},
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": {{ block.settings.text | json }}
                }
              }{% unless forloop.last %},{% endunless %}
            {% endif %}
          {% endfor %}
        ]
      }
    </script>

    <div class="faq-custom-list">
      {%- for block in section.blocks -%}
        <div {{ block.shopify_attributes }}>
          {%- case block.type -%}
            {%- when 'rich-text' -%}
              <div class="index-section index-section--faq">
                <div class="text-{{ block.settings.align_text }}">
                  {%- if block.settings.title != blank -%}
                    <p class="h2">
                      {{ block.settings.title | escape }}
                    </p>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <div class="rte">
                      {{ block.settings.text }}
                    </div>
                  {%- endif -%}
                </div>
              </div>

            {%- when 'question' -%}
              <div class="faq-custom-item">
                <button
                  type="button"
                  class="collapsible-trigger collapsible-trigger--inline collapsible--auto-height text-left faq-custom-trigger"
                  aria-controls="FAQ-content-{{ block.id }}"
                  aria-expanded="false">
                  <span class="faq-custom-question-text">{{ block.settings.title }}</span>
                  <span class="faq-custom-arrow" aria-hidden="true"></span>
                </button>

                <div id="FAQ-content-{{ block.id }}" class="collapsible-content collapsible-content--all faq-custom-content">
                  <div class="collapsible-content__inner collapsible-content__inner--faq rte faq-custom-answer">
                    {{ block.settings.text }}
                  </div>
                </div>
              </div>
          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- if section.blocks.size == 0 -%}
    <div class="placeholder-noblocks">
      {{ 'home_page.onboarding.no_content' | t }}
    </div>
  {%- endif -%}
</div>

{%- if section.settings.divider -%}
  </div>
{%- endif -%}

<style>
  #faq-section-{{ section.id }} {
    font-family: "Montserrat", sans-serif;
  }

  #faq-section-{{ section.id }} .faq-custom-header {
    margin-bottom: 24px;
  }

  #faq-section-{{ section.id }} .faq-custom-title {
    font-family: "Tenor Sans", sans-serif !important;
    font-size: 32px !important;
    line-height: 1.08 !important;
    font-weight: 400 !important;
    letter-spacing: 0.01em !important;
    color: #000000 !important;
    text-transform: none !important;
    text-align: center;
    margin: 0 0 12px 0 !important;
  }

  #faq-section-{{ section.id }} .faq-custom-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  #faq-section-{{ section.id }} .faq-custom-item {
    margin: 0;
  }

  #faq-section-{{ section.id }} .faq-custom-trigger {
    width: 100%;
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    gap: 16px;
    padding: 15px 22px !important;
    border: 0 !important;
    border-radius: 10px !important;
    background: #f7f7f7 !important;
    color: #000000 !important;
    box-shadow: none !important;
    min-height: 56px;
  }

  #faq-section-{{ section.id }} .faq-custom-trigger:hover {
    background: #f7f7f7 !important;
    color: #000000 !important;
  }

  #faq-section-{{ section.id }} .faq-custom-trigger:hover .faq-custom-question-text {
    color: #ededed !important;
  }

  #faq-section-{{ section.id }} .faq-custom-question-text {
    font-family: "Montserrat", sans-serif !important;
    font-size: 14px !important;
    line-height: 1.32 !important;
    font-weight: 600 !important;
    letter-spacing: 0.18em !important;
    text-transform: uppercase !important;
    color: #000000 !important;
    flex: 1 1 auto;
    transition: none !important;
  }

  #faq-section-{{ section.id }} .collapsible-trigger__icon,
  #faq-section-{{ section.id }} .collapsible-trigger .icon,
  #faq-section-{{ section.id }} .faq-custom-trigger svg {
    display: none !important;
  }

  #faq-section-{{ section.id }} .faq-custom-arrow {
    width: 9px;
    height: 9px;
    border-top: 2px solid #000000;
    border-right: 2px solid #000000;
    transform: rotate(45deg);
    flex: 0 0 auto;
    transition: transform 0.2s ease !important;
    margin-left: 12px;
  }

  #faq-section-{{ section.id }} .faq-custom-trigger.is-open .faq-custom-arrow {
    transform: rotate(135deg);
  }

  #faq-section-{{ section.id }} .faq-custom-content {
    background: transparent !important;
  }

  #faq-section-{{ section.id }} .faq-custom-answer {
    padding: 14px 22px 4px 22px !important;
    font-size: 13px !important;
    line-height: 1.6 !important;
    color: #000000 !important;
  }

  #faq-section-{{ section.id }} .faq-custom-answer,
  #faq-section-{{ section.id }} .faq-custom-answer p {
    font-family: "Montserrat", sans-serif !important;
    font-size: 14px !important;
    line-height: 1.6 !important;
    font-weight: 450 !important;
    letter-spacing: 0 !important;
    color: #000000 !important;
    margin: 0 !important;
  }

  #faq-section-{{ section.id }} .faq-custom-answer p + p {
    margin-top: 12px !important;
  }

  @media only screen and (max-width: 768px) {
    #faq-section-{{ section.id }} {
      padding-left: 16px !important;
      padding-right: 16px !important;
    }

    #faq-section-{{ section.id }} .faq-custom-header {
      margin-bottom: 22px;
    }

    #faq-section-{{ section.id }} .faq-custom-title {
      font-family: "Tenor Sans", sans-serif !important;
      font-size: 32px !important;
      line-height: 1.08 !important;
      margin-bottom: 12px !important;
    }

    #faq-section-{{ section.id }} .faq-custom-list {
      gap: 16px;
    }

    #faq-section-{{ section.id }} .faq-custom-trigger {
      padding: 15px 22px !important;
      min-height: 56px;
      border-radius: 10px !important;
    }

    #faq-section-{{ section.id }} .faq-custom-question-text {
      font-size: 13px !important;
      line-height: 1.32 !important;
      font-weight: 520 !important;
      letter-spacing: 0.18em !important;
    }

    #faq-section-{{ section.id }} .faq-custom-answer,
    #faq-section-{{ section.id }} .faq-custom-answer p {
      font-size: 14px !important;
      line-height: 1.58 !important;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const faqSection = document.querySelector('#faq-section-{{ section.id }}');
    if (!faqSection) return;

    const triggers = faqSection.querySelectorAll('.faq-custom-trigger');

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', function () {
        setTimeout(() => {
          const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
          trigger.classList.toggle('is-open', isExpanded);
        }, 10);
      });
    });
  });
</script>

{% schema %}
{
  "name": "t:sections.faq.name",
  "class": "index-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.faq.settings.title.label",
      "default": "FAQS"
    },
    {
      "type": "checkbox",
      "id": "divider",
      "label": "Show section divider",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "rich-text",
      "name": "t:sections.faq.blocks.rich_text.name",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.faq.blocks.rich_text.settings.title.label",
          "default": "Rich text"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:sections.faq.blocks.rich_text.settings.text.label",
          "default": "<p>Use this section for any descriptive text you need to fill out your pages or to add introductory headings between other blocks.</p>"
        },
        {
          "type": "select",
          "id": "align_text",
          "label": "t:sections.faq.blocks.rich_text.settings.align_text.label",
          "default": "left",
          "options": [
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "center",
              "label": "Center"
            },
            {
              "value": "right",
              "label": "Right"
            }
          ]
        }
      ]
    },
    {
      "type": "question",
      "name": "t:sections.faq.blocks.question.name",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.faq.blocks.question.settings.title.label",
          "default": "Frequently asked question"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:sections.faq.blocks.question.settings.text.label",
          "default": "<p>Use this text to answer questions in as much detail as possible for your customers.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.faq.presets.faq.name",
      "blocks": [
        {
          "type": "question"
        },
        {
          "type": "question"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["footer", "header", "custom.popups"]
  }
}
{% endschema %}