<!-- Montserrat font -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@200;400;500;600&display=swap" rel="stylesheet">

<style>
.reviews_stars{
  display:flex;
  align-items:baseline;
  gap:8px;
  text-decoration:none;
  color:#000;
  margin:0 0 10px;
  font-family:'Montserrat', sans-serif; /* 🔥 alles in Montserrat */
}

.reviews_stars .stars{
  position:relative;
  display:inline-block;
  font-size:18px;
  line-height:1;
  color:#cccccc;
  font-family:'Montserrat', sans-serif;
}

.reviews_stars .stars-base,
.reviews_stars .stars-fill{
  display:block;
  white-space:nowrap;
  letter-spacing:0;
}

.reviews_stars .stars-fill{
  position:absolute;
  left:0;
  top:0;
  overflow:hidden;
  color:#ffc502;
  width:0;
}

.reviews_stars .ratings{
  display:flex;
  align-items:baseline;
}

.reviews_stars .ratings span{
  white-space:nowrap;
  color:#000000;
  font-size:15px;
  line-height:1.2;
  font-family:'Montserrat', sans-serif;
}
</style>

<a href="#aus-tp-slider" class="reviews_stars" {{ block.shopify_attributes }}>
  <div class="stars" data-rating="{{ block.settings.tp_rating }}">
    <span class="stars-base">★★★★★</span>
    <span class="stars-fill">★★★★★</span>
  </div>
  <div class="ratings">
    <span>{{ block.settings.review_text | replace: '[rating]', block.settings.tp_rating | replace: '[reviews]', block.settings.tp_reviews }}</span>
  </div>
</a>

<script>
(function(){
  const root = document.currentScript.previousElementSibling;
  if(!root) return;

  const stars = root.querySelector('.stars');
  const fill = root.querySelector('.stars-fill');
  if(!stars || !fill) return;

  let rating = parseFloat(stars.getAttribute('data-rating') || '0');
  if (isNaN(rating)) rating = 0;
  rating = Math.max(0, Math.min(5, rating));

  fill.style.width = (rating / 5 * 100) + '%';
})();
</script>