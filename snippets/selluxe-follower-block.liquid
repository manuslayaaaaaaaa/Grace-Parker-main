{% style %}
  .selluxe-follower__container {
    display: flex;
    justify-content: {{ horizontal_alignment }};
    align-items: center;
    margin: 15px 0;
    font-family: 'Montserrat', sans-serif;
  }

  .selluxe-follower__container .image-container {
    position: relative;
    height: 50px !important;
    width: 50pxpx !important;
    min-width: 50px !important;
    min-height: 50px !important;
    overflow: hidden;
    border-radius: 50%;
    border: 3px solid white;
    flex-shrink: 0;
    aspect-ratio: 1 / 1;
  }

  .trust-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .selluxe-follower__container .image-container:first-child {
    left: 8px;
  }

  .selluxe-follower__container .image-container:nth-child(3) {
    margin-left: -8px;
  }

  .selluxe-follower__text-wrapper {
    margin-left: 12px;
    line-height: 1.35;
    font-size: 13px;
    font-family: 'Montserrat', sans-serif;
    color: inherit;
  }

  .selluxe-follower__text-wrapper,
  .selluxe-follower__text-wrapper span {
    font-size: 13px;
    font-family: 'Montserrat', sans-serif;
    line-height: 1.35;
  }

  .selluxe-follower__headline {
    white-space: nowrap;
  }

  .selluxe-follower__name {
    font-weight: 700;
  }

  .selluxe-follower__badge {
    width: 15px;
    height: 15px;
    display: inline-block;
    object-fit: contain;
    vertical-align: -2px;
    margin: 0 4px 0 3px;
  }
{% endstyle %}

<div class="selluxe-follower__container">
  {% if profile_picture_1 != blank %}
    <div class="image-container">
      <img
        src="{{ profile_picture_1 | image_url: width: 360 }}"
        alt="{{ celebrity_name }}"
        width="52"
        height="52"
        loading="lazy"
        class="trust-image trust-image-1"
      >
    </div>
  {% else %}
    <div class="image-container">
      <img
        src="https://uk.icon-amsterdam.com/cdn/shop/files/rico-verhoeven_500x500.png?v=1706123325"
        alt="{{ celebrity_name }}"
        width="52"
        height="52"
        loading="lazy"
        class="trust-image"
      >
    </div>
  {% endif %}

  {% if profile_picture_2 != blank %}
    <div class="image-container">
      <img
        src="{{ profile_picture_2 | image_url: width: 360 }}"
        alt="{{ celebrity_name }}"
        width="52"
        height="52"
        loading="lazy"
        class="trust-image"
      >
    </div>
  {% endif %}

  {% if profile_picture_3 != blank %}
    <div class="image-container">
      <img
        src="{{ profile_picture_3 | image_url: width: 360 }}"
        alt="{{ celebrity_name }}"
        width="52"
        height="52"
        loading="lazy"
        class="trust-image trust-image-3"
      >
    </div>
  {% endif %}

  <div class="selluxe-follower__text-wrapper">
    <span class="selluxe-follower__headline">
      <span class="selluxe-follower__name">{{ reviewers }}</span>
      {% if show_verified %}
        <img
          src="{{ 'verified-badge.webp' | asset_url }}"
          alt="Verified badge"
          width="15"
          height="15"
          loading="lazy"
          class="selluxe-follower__badge"
        >
      {% endif %}
    </span>
    <span>{{ add_text }}</span>
  </div>
</div>